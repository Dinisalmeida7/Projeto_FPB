NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=fpb_db
DB_POOL_SIZE=10
DB_QUEUE_LIMIT=0

# JWT — gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Mínimo 32 caracteres; o servidor recusa arrancar com um segredo mais curto.
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=24h

# File uploads
UPLOAD_DIR=uploads/
MAX_FILE_SIZE_MB=20

# CORS
ALLOWED_ORIGIN=http://localhost:5173

# HTTP limits
REQUEST_BODY_LIMIT=1mb

# Rate limiting (login endpoint)
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=10

# Rate limiting global da API (todos os endpoints)
RATE_LIMIT_GLOBAL_WINDOW_MIN=15
RATE_LIMIT_GLOBAL_MAX=1000

# Reverse proxy: nº de hops confiáveis (1 atrás de nginx/caddy; 0 ou vazio = sem proxy)
TRUST_PROXY=0
